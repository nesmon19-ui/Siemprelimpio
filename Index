<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lavado Profesional Premium</title>

<style>
body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #f5f7fa;
}

header {
    background: linear-gradient(135deg, #0a2540, #1e3c72);
    color: white;
    text-align: center;
    padding: 50px 20px;
}

header h1 {
    font-size: 32px;
}

.boton {
    display: inline-block;
    background: #25D366;
    color: white;
    padding: 15px 25px;
    margin-top: 20px;
    text-decoration: none;
    border-radius: 8px;
    font-weight: bold;
}

nav {
    background: #0a2540;
    padding: 10px;
    text-align: center;
}

nav a {
    color: white;
    margin: 10px;
    text-decoration: none;
    font-weight: bold;
}

section {
    padding: 40px 20px;
}

.card {
    background: white;
    padding: 20px;
    margin: 15px;
    border-radius: 10px;
    box-shadow: 0px 5px 15px rgba(0,0,0,0.1);
}

.servicios {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
}

.galeria img {
    width: 30%;
    margin: 1%;
    border-radius: 10px;
}

.testimonios {
    display: flex;
    flex-wrap: wrap;
}

.testimonio {
    background: white;
    padding: 20px;
    margin: 10px;
    border-left: 5px solid #25D366;
}

form input, form textarea {
    width: 100%;
    padding: 12px;
    margin: 10px 0;
}

form button {
    background: #0a2540;
    color: white;
    padding: 15px;
    border: none;
    cursor: pointer;
    width: 100%;
}

footer {
    background: #0a2540;
    color: white;
    text-align: center;
    padding: 20px;
}

/* BOTÓN FLOTANTE WHATSAPP */
.whatsapp {
    position: fixed;
    bottom: 20px;
    right: 20px;
    background: #25D366;
    color: white;
    padding: 15px;
    border-radius: 50%;
    text-decoration: none;
    font-size: 20px;
}
</style>

</head>

<body>

<header>
    <h1>Lavado Profesional de Interiores</h1>
    <p>Deja tus muebles y auto como nuevos</p>
    <a class="boton" href="https://wa.me/521XXXXXXXXXX" target="_blank">
        Cotizar por WhatsApp
    </a>
</header>

<nav>
    <a href="#servicios">Servicios</a>
    <a href="#galeria">Galería</a>
    <a href="#testimonios">Opiniones</a>
    <a href="#contacto">Contacto</a>
</nav>

<section id="servicios">
    <h2>Servicios Premium</h2>
    <div class="servicios">
        <div class="card">🚗 Lavado de interiores de autos</div>
        <div class="card">🛋️ Limpieza profunda de salas</div>
        <div class="card">🛏️ Sanitización de colchones</div>
        <div class="card">🦠 Eliminación de olores y bacterias</div>
    </div>
</section>

<section id="galeria">
    <h2>Antes y Después</h2>
    <div class="galeria">
        <img src="https://via.placeholder.com/300">
        <img src="https://via.placeholder.com/300">
        <img src="https://via.placeholder.com/300">
    </div>
    <p>⚠️ Cambia estas imágenes por tus trabajos reales (esto es lo que vende)</p>
</section>

<section id="testimonios">
    <h2>Clientes Satisfechos</h2>
    <div class="testimonios">
        <div class="testimonio">"Mi sala quedó como nueva, excelente servicio"</div>
        <div class="testimonio">"Mi coche parecía recién salido de agencia"</div>
        <div class="testimonio">"Muy profesionales, los recomiendo"</div>
    </div>
</section>

<section>
    <h2>Ubicación</h2>
    <iframe 
        src="https://www.google.com/maps?q=Mexico&output=embed"
        width="100%" height="300" style="border:0;">
    </iframe>
</section>

<section id="contacto">
    <h2>Solicita tu servicio</h2>
    <form>
        <input type="text" placeholder="Nombre" required>
        <input type="tel" placeholder="Teléfono" required>
        <textarea placeholder="¿Qué necesitas limpiar?"></textarea>
        <button type="submit">Enviar solicitud</button>
    </form>
</section>

<footer>
    <p>© 2026 Lavado Profesional | Servicio a domicilio</p>
</footer>

<!-- BOTÓN WHATSAPP -->
<a class="whatsapp" href="https://wa.me/521XXXXXXXXXX" target="_blank">
📲
</a>

</body>
</html>
